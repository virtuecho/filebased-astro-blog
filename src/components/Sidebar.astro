---
import { countItems, formatDate, groupByMonth } from '../lib';
import type { getPublishedPosts } from '../lib';
import { copy } from '../site.config';
import { postUrl } from '../content-workflow';

type Posts = Awaited<ReturnType<typeof getPublishedPosts>>;

interface Props {
  posts: Posts;
}

const { posts } = Astro.props;
const categories = countItems(posts.map((p: Posts[number]) => p.data.category));
const tags = countItems(posts.flatMap((p: Posts[number]) => p.data.tags)).slice(0, 20);
const months = [...groupByMonth(posts).entries()].slice(0, 12);
const recent = posts.slice(0, 8);
---
<aside class="sidebar">
  <section class="sidebar-section">
    <h2 class="sidebar-title">{copy.sidebar.aboutTitle}</h2>
    <p>{copy.sidebar.aboutText}</p>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">{copy.sidebar.recentPosts}</h2>
    <ul>
      {recent.map((post: Posts[number]) => (
        <li><a href={postUrl(post.data, post.id)}>{post.data.title}</a><br /><span class="meta">{formatDate(post.data.date)}</span></li>
      ))}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">{copy.sidebar.categories}</h2>
    <ul>
      {categories.map(([name, count]) => (
        <li><a href={`/category/${encodeURIComponent(name)}/`}>{name}</a> ({count})</li>
      ))}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">{copy.sidebar.tags}</h2>
    <div class="tag-list">
      {tags.map(([name, count]) => (
        <a class="tag" href={`/tag/${encodeURIComponent(name)}/`}>{name} {count}</a>
      ))}
    </div>
  </section>

  <section class="sidebar-section">
    <h2 class="sidebar-title">{copy.sidebar.archives}</h2>
    <ul>
      {months.map(([month, list]) => {
        const [year, mm] = month.split('/');
        return <li><a href={`/archives/${year}/${mm}/`}>{month}</a> ({list.length})</li>;
      })}
    </ul>
  </section>
</aside>
