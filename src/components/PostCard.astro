---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib';
import { copy } from '../site.config';
import { postUrl } from '../content-workflow';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const url = postUrl(post.data, post.id);
---
<article class="post-card">
  <a href={url} aria-label={post.data.title}>
    {post.data.cover ? (
      <img class="post-card-cover" src={post.data.cover} alt={post.data.title} loading="lazy" />
    ) : (
      <div class="post-card-cover"></div>
    )}
  </a>
  <div>
    <h2 class="post-card-title"><a href={url}>{post.data.title}</a></h2>
    <div class="meta">
      {formatDate(post.data.date)} | {copy.labels.category}: <a href={`/category/${encodeURIComponent(post.data.category)}/`}>{post.data.category}</a>
    </div>
    {post.data.description && <p class="excerpt">{post.data.description}</p>}
    <div class="tag-list">
      {post.data.tags.map((tag: string) => <a class="tag" href={`/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
    </div>
  </div>
</article>
