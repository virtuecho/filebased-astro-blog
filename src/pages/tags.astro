---
import BaseLayout from '../layouts/BaseLayout.astro';
import { countItems, getPublishedPosts } from '../lib';
import { copy } from '../site.config';
const posts = await getPublishedPosts();
const tags = countItems(posts.flatMap((p) => p.data.tags));
---
<BaseLayout title={copy.pages.tagsTitle}>
  <h1 class="page-title">{copy.pages.tagsTitle}</h1>
  <div class="tag-list">
    {tags.map(([name, count]) => <a class="tag" href={`/tag/${encodeURIComponent(name)}/`}>{name} {count}</a>)}
  </div>
</BaseLayout>
