---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, groupByMonth } from '../lib';
import { copy } from '../site.config';
const posts = await getPublishedPosts();
const months = [...groupByMonth(posts).entries()];
---
<BaseLayout title={copy.pages.archivesTitle}>
  <h1 class="page-title">{copy.pages.archivesTitle}</h1>
  <ul class="simple-list">
    {months.map(([month, list]) => {
      const [year, mm] = month.split('/');
      return <li><a href={`/archives/${year}/${mm}/`}>{month}</a> ({list.length})</li>;
    })}
  </ul>
</BaseLayout>
