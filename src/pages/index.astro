---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib';
import { copy } from '../site.config';
const posts = await getPublishedPosts();
---
<BaseLayout title={copy.site.title}>
  <h1 class="page-title">{copy.home.title}</h1>
  {copy.home.notice && <div class="notice">{copy.home.notice}</div>}
  <div style="margin-top: 18px;">
    {posts.length > 0 ? posts.map((post) => <PostCard post={post} />) : <p class="meta">{copy.home.empty}</p>}
  </div>
</BaseLayout>
