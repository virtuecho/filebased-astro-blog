{
  "name": "astro-file-blog-template",
  "version": "0.1.0",
  "description": "An Astro static blog template with Markdown posts and a local browser admin.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "new-post": "tsx scripts/new-post.mjs",
    "edit-post": "tsx scripts/edit-post.mjs",
    "update-slug": "tsx scripts/update-slug.mjs",
    "preview-post": "tsx scripts/preview-post.mjs",
    "open-assets": "tsx scripts/open-assets.mjs",
